from datetime import datetime, date, timedelta

pattern = '%d.%m.%Y'
start_date = datetime.strptime('07.03.2021', pattern)
stop_date = datetime.strptime('13.03.2021', pattern).date()
one_day_gap = timedelta(days = 1)
while (start_date.day + start_date.month) % 2 == 0:
    start_date = start_date + one_day_gap
for procesed_date in range(start_date.toordinal(), stop_date.toordinal() + 1, 3):
    cur_date = datetime.fromordinal(procesed_date)
    if cur_date.isoweekday() != 1 and cur_date.isoweekday() != 4:
        print(cur_date.strftime(pattern))