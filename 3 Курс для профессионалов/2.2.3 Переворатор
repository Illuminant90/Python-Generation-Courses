n, x, y, a, b = [int(digit) for digit in '5 1 3 4 5'.split()]
#n, x, y, a, b = [int(digit) for digit in input().split()]
numbers = list(range(1, n + 1))
seq_rev = numbers[x - 1:y]
seq_rev.reverse()
numbers = numbers[:x - 1] + seq_rev + numbers[y:]
seq_rev = numbers[a - 1:b]
seq_rev.reverse()
numbers = numbers[:a - 1] + seq_rev + numbers[b:]
print(*numbers)
