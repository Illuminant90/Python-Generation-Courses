words = tuple([word.strip('.,!?:;-').lower() for word in input().split()])
output = {}
for word in words:
    if word in output:
        output[word] += 1
    else:
        output.setdefault(word, 1)
rarest_count = min(output.values())
result = tuple([word for word in output if output[word] == rarest_count])
print(min(result))