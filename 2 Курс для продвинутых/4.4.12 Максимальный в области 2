n = int(input())
matrix = [[int(i) for i in input().split()] for _ in range(n)]
record = min(matrix[0])
for i in range(n):
    for j in range(n):
        is_in_zone = (i >= j and i <= n - 1 - j) or (i <= j and 1 > n - 1 - j)
        if is_in_zone:
            print(f'matrix{i}{j} = {matrix[i][j]}')
            if matrix[i][j] > record:
                record = matrix[i][j]
                print(f'record = {record}')              
print(record)