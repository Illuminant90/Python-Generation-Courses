import random

n = 10**6       # количество испытаний
k = 0
s0 = 4 * 4
for _ in range(n):
    x = random.uniform(-2, 2)     # случайное число с плавающей точкой от 0 до 1
    y = random.uniform(-2, 2)     # случайное число с плавающей точкой от 0 до 1
    inequality_1 = x ** 3 + y ** 4 + 2 >= 0
    inequality_2 = 3 * x + y ** 2 <= 2
    if inequality_1 and inequality_2:                # если попадает в нужную область
        k += 1

print((k/n)*s0)